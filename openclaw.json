{
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-2.5-flash"
      },
      "workspace": "./workspace",
      "skills": ["swiggy"]
    }
  },
  "models": {
    "providers": {
      "google": {
        "api": "google-generative-ai",
        "apiKey": "${GEMINI_API_KEY}"
      },
      "openrouter": {
        "apiKey": "${OPENROUTER_API_KEY}"
      },
      "opencode-go": {
        "apiKey": "${OPENCODE_GO_API_KEY}",
        "baseUrl": "${OPENCODE_GO_BASE_URL}"
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": ["./skills"]
    }
  }
}
