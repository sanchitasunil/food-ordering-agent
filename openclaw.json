{
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-2.5-flash"
      },
      "workspace": "./workspace",
      "skills": ["swiggy"]
    }
  },
  "models": {
    "providers": {
      "google": {
        "api": "google-generative-ai",
        "apiKey": "${GEMINI_API_KEY}"
      },
      "openrouter": {
        "apiKey": "${OPENROUTER_API_KEY}"
      },
      "opencode": {},
      "opencode-go": {}
    }
  },
  "skills": {
    "load": {
      "extraDirs": ["./skills"]
    }
  },
  "plugins": {
    "entries": {
      "murf": { "enabled": false },
      "murf-tts": { "enabled": false }
    }
  }
}
