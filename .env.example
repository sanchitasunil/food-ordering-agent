# ─── Voice & ASR ────────────────────────────────────────────────
MURF_API_KEY=your_murf_key_here
DEEPGRAM_API_KEY=your_deepgram_key_here

# ─── Swiggy ─────────────────────────────────────────────────────
# Optional / unused — Swiggy MCP auth is handled by mcporter via OAuth
# (run `mcporter auth swiggy-food` once). Leave blank or remove.
SWIGGY_API_KEY=your_swiggy_key_here_if_required

# ─── LLM provider switching ─────────────────────────────────────
# Pick which LLM provider the agent uses. Switch when one hits rate
# limits — no code change needed, just edit this line and restart.
#
#   gemini       → Google Gemini 2.5 Flash, direct API   (needs GEMINI_API_KEY)
#   openrouter   → MiniMax M2.5 via OpenRouter           (needs OPENROUTER_API_KEY)
#   opencode-go  → A free model via opencode-go gateway  (needs OPENCODE_GO_*)
#
LLM_PROVIDER=gemini

# Optional: pin a specific model on the active provider. If unset, brain.ts
# picks the default model for whichever provider is selected above.
# Examples:
#   LLM_MODEL=google/gemini-2.5-flash
#   LLM_MODEL=openrouter/minimax/minimax-m2.5
#LLM_MODEL=

# ─── Provider keys (set the ones you use) ───────────────────────
GEMINI_API_KEY=your_gemini_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# opencode-go: configure the key and base URL once you know the service.
# Leave commented out if you're not using this provider.
#OPENCODE_GO_API_KEY=your_opencode_go_key_here
#OPENCODE_GO_BASE_URL=https://your-opencode-go-host.example/v1
